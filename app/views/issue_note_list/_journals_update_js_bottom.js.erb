(() => {
  const controller = Array(
    ...document.getElementsByTagName("body")[0].classList,
  )
    .filter((e) => e.startsWith("controller-"))[0]
    ?.replace("controller-", "");
  if (controller === "issue_note_list") {
    $.ajax({
      url: "<%= escape_javascript(issue_note_list_refresh_notes_path(@journal.issue.id)) %>",
      type: "GET",
      dataType: "script",
    });
  }
})();
