(() => {
  // Close all pop-out contents
  $(".ui-dialog-content.journal.issue-<%= @issue.id %>").dialog("close");

  // Update rows
  const $notes = $("#issue-<%= @issue.id %>").children(".recent_notes");
  $notes.empty().append($(
    '<%= escape_javascript(render_issue_notes(
        @issue,
        @query.number_of_notes,
        @query.private_notes_filter,
        @query.note_type_op,
        @query.note_type_v)) %>'
  ));

  // Regenerate GLightbox if exists
  if (window.redmineGLightbox) {
    window.redmineGLightbox.regenerate();
  }
})();
